# 复制本文件为 .env 后按需修改

# 发起人（审核员）登录口令。首次启动会据此生成口令；
# 若留空，则首次在网页「发起人登录」中输入的口令将被设为口令。
ADMIN_PASSCODE=change-this-passcode

# 监听端口
PORT=3000

# 是否由本服务同时托管前端静态文件（all-in-one 单域名部署）。
# 置为 1 时，访问 http://你的地址:端口/ 即是前端页面，且无需跨域。
SERVE_WEB=0

# 自定义前端目录（SERVE_WEB=1 时生效），默认是同级的 ../web
# WEB_DIR=/path/to/web

# 数据与上传目录（默认在 server/ 下的 data 与 uploads）
# DATA_DIR=/path/to/data
# UPLOAD_DIR=/path/to/uploads
