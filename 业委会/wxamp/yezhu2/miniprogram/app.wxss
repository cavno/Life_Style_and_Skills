page {
  --bg: #e5e7eb;
  --card: #ffffff;
  --card-soft: #eef0f3;
  --chrome: #e9ebef;
  --ink: #1f2328;
  --ink-2: #545d68;
  --ink-3: #8a909a;
  --line: #d7dbe0;
  --brand: #2a6cd6;
  --brand-soft: #e4ecf8;
  --ok: #1a7f37;
  --ok-soft: #e2f0e6;
  --warn: #b35900;
  --warn-soft: #f7ecdd;
  --danger: #cf222e;

  background: var(--bg);
  color: var(--ink);
  font-size: 30rpx;
  line-height: 1.55;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
}

.wrap { padding: 24rpx 24rpx 60rpx; }

.card {
  background: var(--card);
  border: 1rpx solid var(--line);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 10rpx rgba(31, 41, 55, .04);
}

.h1 { font-size: 40rpx; font-weight: 600; letter-spacing: .5rpx; }
.h2 { font-size: 32rpx; font-weight: 600; margin-bottom: 16rpx; }
.muted { color: var(--ink-2); }
.dim { color: var(--ink-3); font-size: 26rpx; }
.row { display: flex; align-items: center; }
.between { justify-content: space-between; }
.mt8 { margin-top: 8rpx; } .mt16 { margin-top: 16rpx; } .mt24 { margin-top: 24rpx; }

/* 进度条 */
.bar { height: 18rpx; background: var(--line); border-radius: 999rpx; overflow: hidden; }
.bar > i { display: block; height: 100%; background: var(--brand); border-radius: 999rpx; transition: width .4s ease; }
.bar.ok > i { background: var(--ok); }

/* 徽标 */
.badge { display: inline-block; padding: 4rpx 18rpx; border-radius: 999rpx; font-size: 24rpx; }
.badge.ok { background: var(--ok-soft); color: var(--ok); }
.badge.wait { background: var(--warn-soft); color: var(--warn); }
.badge.no { background: #fbeaec; color: var(--danger); }

/* 按钮 */
.btn {
  display: block; width: 100%; box-sizing: border-box;
  background: var(--brand); color: #fff; border: none;
  border-radius: 14rpx; padding: 24rpx; font-size: 32rpx; font-weight: 500;
}
.btn[disabled] { background: #c9d3e0; color: #fff; }
.btn.ghost { background: var(--brand-soft); color: var(--brand); }
.btn.line { background: #fff; color: var(--ink); border: 1rpx solid var(--line); }
.btn.danger { background: #fff; color: var(--danger); border: 1rpx solid #f3c0c5; }
.btn.sm { padding: 14rpx 24rpx; font-size: 28rpx; width: auto; display: inline-block; }

/* 表单 */
.field { margin-bottom: 28rpx; }
.label { font-size: 28rpx; color: var(--ink-2); margin-bottom: 12rpx; }
.label .req { color: var(--danger); margin-left: 6rpx; }
.input, .textarea {
  width: 100%; box-sizing: border-box;
  background: var(--card-soft); border: 1rpx solid var(--line);
  border-radius: 12rpx; padding: 24rpx; font-size: 30rpx;
  min-height: 96rpx; line-height: 1.5; color: var(--ink);
}
.textarea { min-height: 180rpx; }

/* 楼栋房号：下拉 + 后缀 */
.addr { display: flex; gap: 14rpx; align-items: stretch; }
.addr-cell { flex: 1; display: flex; align-items: center; gap: 8rpx; min-width: 0; }
.addr-cell .input { padding: 24rpx 12rpx; text-align: center; }
.picker {
  flex: 1; min-width: 0; box-sizing: border-box;
  background: var(--card-soft); border: 1rpx solid var(--line);
  border-radius: 12rpx; padding: 24rpx 16rpx; font-size: 30rpx;
  min-height: 96rpx; line-height: 1.5; color: var(--ink);
  display: flex; align-items: center; justify-content: center;
}
.picker.ph { color: var(--ink-3); }
.addr-cell .suf { flex: none; font-size: 28rpx; color: var(--ink-2); }
.custom-row { display: flex; align-items: center; gap: 16rpx; margin-top: 16rpx; }
.custom-row .custom-label { flex: none; font-size: 28rpx; color: var(--ink-2); }
.custom-row .input { flex: 1; }

.three { display: flex; gap: 16rpx; }
.three .input { flex: 1; }

.kv { display: flex; justify-content: space-between; padding: 14rpx 0; border-bottom: 1rpx solid var(--line); }
.kv:last-child { border-bottom: none; }
.kv .k { color: var(--ink-2); }
.kv .v { font-weight: 500; }

.empty { text-align: center; color: var(--ink-3); padding: 80rpx 0; }
