.notice { background: var(--brand-soft); color: #1a4f9c; padding: 18rpx 22rpx; border-radius: 12rpx; font-size: 27rpx; }
.warnbox { background: var(--warn-soft); color: var(--warn); padding: 18rpx 22rpx; border-radius: 12rpx; font-size: 27rpx; }
.metric .pct { font-size: 34rpx; font-weight: 600; color: var(--brand); }
.metric .pct.ok { color: var(--ok); }
.hint { background: var(--card-soft); padding: 18rpx 22rpx; border-radius: 12rpx; color: var(--ink-2); font-size: 27rpx; }
.hint.ok { background: var(--ok-soft); color: var(--ok); }
.counts { display: flex; }
.counts .cell { flex: 1; text-align: center; }
.counts .num { font-size: 48rpx; font-weight: 700; }
.counts .num.warn { color: var(--warn); }

/* v2 追加：迷你路线图 */
.roadmap { display: flex; align-items: flex-start; }
.rm-node { display: flex; flex-direction: column; align-items: center; width: 72rpx; flex: none; }
.rm-dot {
  width: 48rpx; height: 48rpx; border-radius: 50%; background: var(--line);
  color: var(--ink-3); text-align: center; line-height: 48rpx; font-size: 26rpx; font-weight: 700;
}
.rm-node.cur .rm-dot { background: var(--brand); color: #fff; }
.rm-node.done .rm-dot { background: var(--ok-soft); color: var(--ok); }
.rm-label { font-size: 22rpx; color: var(--ink-3); margin-top: 8rpx; }
.rm-node.cur .rm-label { color: var(--brand); font-weight: 600; }
.rm-line { flex: 1; height: 4rpx; background: var(--line); margin-top: 22rpx; }
.rm-line.done { background: var(--ok); }
