.seg { display: flex; gap: 16rpx; }
.seg-i { flex: 1; text-align: center; padding: 20rpx 0; border: 1rpx solid var(--line); border-radius: 12rpx; color: var(--ink-2); font-size: 28rpx; background: var(--card-soft); }
.seg-i.on { background: var(--brand-soft); color: var(--brand); border-color: var(--brand-soft); font-weight: 600; }

/* 阶段选择器：做成与输入框一致的高度 */
.picker { background: var(--card-soft); border: 1rpx solid var(--line); border-radius: 12rpx; padding: 24rpx; font-size: 30rpx; min-height: 96rpx; line-height: 1.5; box-sizing: border-box; display: flex; align-items: center; }
